rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact form: anyone can create, only admin can read/update
    match /contact_submissions/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'inquiry', 'message'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.message is string;
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }

    // Portal collections: admin only
    match /portal_clients/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
    match /portal_documents/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
    match /portal_invoices/{docId} {
      allow read: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com'
                  || resource.data.magicToken == request.query.get('token', '');
      allow write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }

    // Rupert banner note (written by the mini via Admin SDK; owner reads it)
    match /rupert/{doc} {
      allow read: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
      allow write: if false;
    }

    // Coding Projects workspace (coding.html) — owner only.
    match /coding_items/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
    match /coding_meta/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
    // Secrets INDEX — names/locations/rotation only, never values. Owner only.
    match /coding_secrets/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
    match /coding_roadmap/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'mdulin@gmail.com';
    }
  }
}
